---
import { getAllArticles, getArticleBySlug } from '../../lib/directus';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return (articles as any[]).map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug as string);

if (!article) {
  return Astro.redirect('/404');
}

const bodyHtml = await marked(article.body || '');

const internalLinks = (article.internal_links || []) as Array<{
  article_id: number;
  slug: string;
  anchor_text: string;
}>;

const faqSchema = article.faq_items?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: (article.faq_items as any[]).map((faq: any) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }
  : null;

const siteUrl = import.meta.env.SITE_URL || '';
const canonicalUrl = article.canonical_url || `${siteUrl}/articles/${article.slug}`;
---

<BaseLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    {article.robots && <meta name="robots" content={article.robots} />}

    <meta property="og:title" content={article.og_title || article.meta_title || article.title} />
    <meta property="og:description" content={article.og_description || article.meta_description || article.excerpt || ''} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />

    {article.published_at && <meta property="article:published_time" content={article.published_at} />}
    {(article.categories as any[])?.map((cat: any) => (
      <meta property="article:section" content={cat.categories_id?.name} />
    ))}
    {(article.tags as any[])?.map((tag: any) => (
      <meta property="article:tag" content={tag.tags_id?.name} />
    ))}

    {article.structured_data && (
      <script type="application/ld+json" set:html={JSON.stringify(article.structured_data)} />
    )}
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}

    <style>
      article header { margin-bottom: 32px; }
      article h1 { font-size: 2rem; font-weight: 700; line-height: 1.2; margin-bottom: 12px; }
      .excerpt { font-size: 1.1rem; color: #555; margin-bottom: 8px; }
      time { font-size: 0.875rem; color: #888; }
      .content h2 { font-size: 1.5rem; font-weight: 600; margin: 2rem 0 0.75rem; }
      .content h3 { font-size: 1.2rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
      .content p { margin-bottom: 1rem; }
      .content ul, .content ol { margin-bottom: 1rem; padding-left: 1.5rem; }
      .content li { margin-bottom: 0.35rem; }
      .content blockquote { border-left: 3px solid #2563eb; padding: 0.5rem 1rem; margin: 1rem 0; color: #555; font-style: italic; }
      .content table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
      .content th, .content td { padding: 8px 12px; text-align: left; border: 1px solid #e5e7eb; font-size: 0.9rem; }
      .content th { background: #f9fafb; font-weight: 600; }
      .content code { background: #f3f4f6; padding: 2px 6px; border-radius: 4px; font-size: 0.9em; }
      .content pre { background: #1e1e1e; color: #d4d4d4; padding: 16px; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
      .content pre code { background: none; padding: 0; color: inherit; }
      .faq { margin-top: 3rem; border-top: 1px solid #e5e7eb; padding-top: 2rem; }
      .faq h2 { font-size: 1.3rem; margin-bottom: 1rem; }
      details { margin-bottom: 0.75rem; }
      summary { cursor: pointer; font-weight: 500; padding: 8px 0; }
      details p { padding: 4px 0 12px 16px; color: #555; }
      .related-articles { margin-top: 3rem; border-top: 1px solid #e5e7eb; padding-top: 2rem; }
      .related-articles h2 { font-size: 1.2rem; margin-bottom: 0.75rem; }
      .related-articles ul { list-style: none; padding: 0; }
      .related-articles li { margin-bottom: 0.5rem; }
    </style>
  </Fragment>

  <article>
    <header>
      <h1>{article.title}</h1>
      {article.excerpt && <p class="excerpt">{article.excerpt}</p>}
      {article.published_at && (
        <time datetime={article.published_at}>
          {new Date(article.published_at).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      )}
    </header>

    <div class="content" set:html={bodyHtml} />

    {article.faq_items && (article.faq_items as any[]).length > 0 && (
      <section class="faq">
        <h2>Frequently Asked Questions</h2>
        {(article.faq_items as any[]).map((faq: any) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </section>
    )}

    {internalLinks.length > 0 && (
      <nav class="related-articles">
        <h2>Related Articles</h2>
        <ul>
          {internalLinks.map((link) => (
            <li><a href={`/articles/${link.slug}`}>{link.anchor_text}</a></li>
          ))}
        </ul>
      </nav>
    )}
  </article>
</BaseLayout>
