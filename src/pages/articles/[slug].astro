---
import { getAllArticles, getArticleBySlug } from '../../lib/directus';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return (articles as any[]).map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug as string);

if (!article) {
  return Astro.redirect('/404');
}

const bodyHtml = await marked(article.body || '');

const internalLinks = (article.internal_links || []) as Array<{
  article_id: number;
  slug: string;
  anchor_text: string;
}>;

const faqSchema = article.faq_items?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: (article.faq_items as any[]).map((faq: any) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }
  : null;

const siteUrl = import.meta.env.SITE_URL || '';
const canonicalUrl = article.canonical_url || `${siteUrl}/articles/${article.slug}`;
---

<BaseLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    {article.robots && <meta name="robots" content={article.robots} />}

    <meta property="og:title" content={article.og_title || article.meta_title || article.title} />
    <meta property="og:description" content={article.og_description || article.meta_description || article.excerpt || ''} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />

    {article.published_at && <meta property="article:published_time" content={article.published_at} />}
    {(article.categories as any[])?.map((cat: any) => (
      <meta property="article:section" content={cat.categories_id?.name} />
    ))}
    {(article.tags as any[])?.map((tag: any) => (
      <meta property="article:tag" content={tag.tags_id?.name} />
    ))}

    {article.structured_data && (
      <script type="application/ld+json" set:html={JSON.stringify(article.structured_data)} />
    )}
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <article class="article">
    <header class="article-header">
      <h1>{article.title}</h1>
      {article.excerpt && <p class="article-excerpt">{article.excerpt}</p>}
      {article.published_at && (
        <time datetime={article.published_at}>
          {new Date(article.published_at).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      )}
    </header>

    <div class="article-body" set:html={bodyHtml} />

    {article.faq_items && (article.faq_items as any[]).length > 0 && (
      <section class="article-faq">
        <h2>Frequently Asked Questions</h2>
        {(article.faq_items as any[]).map((faq: any) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </section>
    )}

    {internalLinks.length > 0 && (
      <nav class="article-related">
        <h2>Related Articles</h2>
        <ul>
          {internalLinks.map((link) => (
            <li><a href={`/articles/${link.slug}`}>{link.anchor_text}</a></li>
          ))}
        </ul>
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  /* ── Article header ── */
  .article-header {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }
  .article-header h1 {
    font-family: var(--displayFont);
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 12px;
    color: var(--text);
  }
  .article-excerpt {
    font-size: 17px;
    color: var(--textMuted);
    line-height: 1.6;
    max-width: 640px;
    margin-bottom: 12px;
  }
  time {
    font-size: 13px;
    color: var(--textFaint);
  }

  /* ── Article body ── */
  .article-body :global(h2) {
    font-family: var(--displayFont);
    font-size: 24px;
    font-weight: 600;
    margin: 40px 0 16px;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .article-body :global(h3) {
    font-size: 18px;
    font-weight: 600;
    margin: 28px 0 12px;
    color: var(--text);
  }
  .article-body :global(p) {
    font-size: 15px;
    line-height: 1.7;
    color: var(--textMuted);
    margin-bottom: 16px;
  }
  .article-body :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }
  .article-body :global(li) {
    font-size: 15px;
    line-height: 1.7;
    color: var(--textMuted);
    margin-bottom: 6px;
  }
  .article-body :global(blockquote) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 20px 24px;
    margin: 20px 0;
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
  }
  .article-body :global(blockquote p) {
    margin-bottom: 8px;
  }
  .article-body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  .article-body :global(blockquote strong) {
    color: var(--text);
  }
  .article-body :global(a) {
    color: var(--accent);
    text-decoration: none;
  }
  .article-body :global(a:hover) {
    text-decoration: underline;
  }
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14px;
  }
  .article-body :global(th),
  .article-body :global(td) {
    padding: 10px 14px;
    text-align: left;
    border: 1px solid var(--border);
    color: var(--textMuted);
  }
  .article-body :global(th) {
    background: var(--surface);
    font-weight: 600;
    color: var(--text);
    font-size: 13px;
  }
  .article-body :global(code) {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.9em;
    color: var(--accent);
  }
  .article-body :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 20px 0;
    overflow-x: auto;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 13px;
    line-height: 1.6;
    color: var(--textMuted);
  }
  .article-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }
  .article-body :global(em) {
    font-style: italic;
  }
  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }

  /* ── FAQ ── */
  .article-faq {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .article-faq h2 {
    font-family: var(--displayFont);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 16px;
    color: var(--text);
  }
  details {
    margin-bottom: 8px;
    padding: 12px 16px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  details[open] {
    border-color: var(--accent);
  }
  summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    color: var(--text);
    padding: 4px 0;
  }
  details p {
    padding: 8px 0 4px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
  }

  /* ── Related articles ── */
  .article-related {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .article-related h2 {
    font-family: var(--displayFont);
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--text);
  }
  .article-related ul {
    list-style: none;
    padding: 0;
  }
  .article-related li {
    margin-bottom: 8px;
  }
  .article-related a {
    font-size: 14px;
    color: var(--accent);
  }

  @media (max-width: 700px) {
    .article-header h1 { font-size: 30px; }
    .article-excerpt { font-size: 15px; }
  }
</style>
