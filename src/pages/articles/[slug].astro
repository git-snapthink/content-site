---
import { getAllArticles, getArticleBySlug } from '../../lib/directus';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return (articles as any[]).map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = await getArticleBySlug(slug as string);

if (!article) {
  return Astro.redirect('/404');
}

const bodyHtml = await marked(article.body || '');

const internalLinks = (article.internal_links || []) as Array<{
  article_id: number;
  slug: string;
  anchor_text: string;
}>;

const faqSchema = article.faq_items?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: (article.faq_items as any[]).map((faq: any) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    }
  : null;

const siteUrl = import.meta.env.SITE_URL || '';
const canonicalUrl = article.canonical_url || `${siteUrl}/articles/${article.slug}`;

// Extract h2/h3 headings from markdown for TOC sidebar
const headingRegex = /^(#{2,3})\s+(.+)$/gm;
const tocItems: Array<{ level: number; text: string; id: string }> = [];
let match;
const rawBody = article.body || '';
while ((match = headingRegex.exec(rawBody)) !== null) {
  const level = match[1].length;
  const text = match[2].replace(/[*_`\[\]]/g, '');
  const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  tocItems.push({ level, text, id });
}

// Configure marked to add IDs to headings
const renderer = new marked.Renderer();
renderer.heading = ({ text, depth }: { text: string; depth: number }) => {
  const rawText = text.replace(/<[^>]+>/g, '');
  const id = rawText.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  return `<h${depth} id="${id}">${text}</h${depth}>`;
};
const bodyHtmlWithIds = await marked(rawBody, { renderer });

const categories = ((article.categories || []) as any[])
  .map((c: any) => c.categories_id?.name)
  .filter(Boolean);
const tags = ((article.tags || []) as any[])
  .map((t: any) => t.tags_id?.name)
  .filter(Boolean);
---

<BaseLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    {article.robots && <meta name="robots" content={article.robots} />}

    <meta property="og:title" content={article.og_title || article.meta_title || article.title} />
    <meta property="og:description" content={article.og_description || article.meta_description || article.excerpt || ''} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />

    {article.published_at && <meta property="article:published_time" content={article.published_at} />}
    {(article.categories as any[])?.map((cat: any) => (
      <meta property="article:section" content={cat.categories_id?.name} />
    ))}
    {(article.tags as any[])?.map((tag: any) => (
      <meta property="article:tag" content={tag.tags_id?.name} />
    ))}

    {article.structured_data && (
      <script type="application/ld+json" set:html={JSON.stringify(article.structured_data)} />
    )}
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <div class="page-header">
    <h1>{article.title}</h1>
    {article.excerpt && <p>{article.excerpt}</p>}
  </div>

  <div class="docs-layout">
    <aside class="docs-sidebar">
      {article.published_at && (
        <div class="sidebar-meta">
          <time datetime={article.published_at}>
            {new Date(article.published_at).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </div>
      )}

      {tocItems.length > 0 && (
        <>
          <h4>On This Page</h4>
          <ul>
            {tocItems.map((item) => (
              <li>
                <a href={`#${item.id}`} class:list={[{ nested: item.level === 3 }]}>{item.text}</a>
              </li>
            ))}
          </ul>
        </>
      )}

      {categories.length > 0 && (
        <>
          <h4>Categories</h4>
          <ul>
            {categories.map((name) => (
              <li><span class="sidebar-tag">{name}</span></li>
            ))}
          </ul>
        </>
      )}

      {tags.length > 0 && (
        <>
          <h4>Tags</h4>
          <div class="sidebar-tags">
            {tags.map((name) => (
              <span class="sidebar-tag">{name}</span>
            ))}
          </div>
        </>
      )}

      {internalLinks.length > 0 && (
        <>
          <h4>Related Articles</h4>
          <ul>
            {internalLinks.map((link) => (
              <li><a href={`/articles/${link.slug}`}>{link.anchor_text}</a></li>
            ))}
          </ul>
        </>
      )}
    </aside>

    <article class="docs-body">
      <div class="article-body" set:html={bodyHtmlWithIds} />

      {article.faq_items && (article.faq_items as any[]).length > 0 && (
        <section class="article-faq">
          <h2 id="faq">Frequently Asked Questions</h2>
          {(article.faq_items as any[]).map((faq: any) => (
            <details>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </section>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  /* ── Page header ── */
  .page-header {
    margin-bottom: 48px;
  }
  .page-header h1 {
    font-family: var(--displayFont);
    font-size: 42px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 12px;
    color: var(--text);
  }
  .page-header p {
    font-size: 17px;
    color: var(--textMuted);
    line-height: 1.6;
    max-width: 640px;
  }

  /* ── Docs layout ── */
  .docs-layout {
    display: flex;
    gap: 40px;
  }

  /* ── Sidebar ── */
  .docs-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 32px;
    align-self: flex-start;
  }
  .sidebar-meta {
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-meta time {
    font-size: 12px;
    color: var(--textFaint);
  }
  .docs-sidebar h4 {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--textFaint);
    margin-bottom: 12px;
  }
  .docs-sidebar ul {
    list-style: none;
    margin-bottom: 24px;
    padding: 0;
  }
  .docs-sidebar li {
    margin-bottom: 2px;
  }
  .docs-sidebar a {
    display: block;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 13px;
    color: var(--textMuted);
    text-decoration: none;
    transition: all 0.15s;
  }
  .docs-sidebar a:hover {
    color: var(--text);
    background: var(--surface);
    text-decoration: none;
  }
  .docs-sidebar a.nested {
    padding-left: 24px;
    font-size: 12px;
  }
  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }
  .sidebar-tag {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
  }

  /* ── Docs body ── */
  .docs-body {
    flex: 1;
    min-width: 0;
  }

  /* ── Article body ── */
  .article-body :global(h2) {
    font-size: 24px;
    font-weight: 600;
    margin: 28px 0 16px;
    color: var(--text);
  }
  .article-body :global(h3) {
    font-size: 18px;
    font-weight: 600;
    margin: 28px 0 12px;
    color: var(--text);
  }
  .article-body :global(p) {
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
    margin-bottom: 16px;
  }
  .article-body :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }
  .article-body :global(li) {
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
    margin-bottom: 6px;
  }
  .article-body :global(blockquote) {
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 20px 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--textMuted);
  }
  .article-body :global(blockquote p) {
    margin-bottom: 8px;
  }
  .article-body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  .article-body :global(blockquote strong) {
    color: var(--text);
  }
  .article-body :global(a) {
    color: var(--accent);
    text-decoration: none;
  }
  .article-body :global(a:hover) {
    text-decoration: underline;
  }
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14px;
  }
  .article-body :global(th),
  .article-body :global(td) {
    padding: 10px 14px;
    text-align: left;
    border: 1px solid var(--border);
    color: var(--textMuted);
  }
  .article-body :global(th) {
    background: var(--surface);
    font-weight: 600;
    color: var(--text);
    font-size: 13px;
  }
  .article-body :global(code) {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.9em;
    color: var(--accent);
  }
  .article-body :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 20px 0;
    overflow-x: auto;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 13px;
    line-height: 1.6;
    color: var(--textMuted);
  }
  .article-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }
  .article-body :global(em) {
    font-style: italic;
  }
  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }

  /* ── FAQ ── */
  .article-faq {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .article-faq h2 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 16px;
    color: var(--text);
  }
  details {
    margin-bottom: 8px;
    padding: 12px 16px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  details[open] {
    border-color: var(--accent);
  }
  summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    color: var(--text);
    padding: 4px 0;
  }
  details p {
    padding: 8px 0 4px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
  }

  @media (max-width: 900px) {
    .docs-layout {
      flex-direction: column;
    }
    .docs-sidebar {
      width: 100%;
      position: static;
    }
  }
  @media (max-width: 700px) {
    .page-header h1 { font-size: 30px; }
    .page-header p { font-size: 15px; }
  }
</style>
