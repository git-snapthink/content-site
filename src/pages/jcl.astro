---
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Operator's Log — Jason C. Lewis</title>
<meta name="description" content="Practical AI perspective from someone who's been building and advising for 14 years. Weekly newsletter from the operator's seat." />
<link rel="icon" type="image/svg+xml" href="/favicon-jcl.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Chakra+Petch:wght@400;500;600&family=Orbitron:wght@600;700&display=swap" rel="stylesheet" />
<GoogleAnalytics id={gaId} />
<style is:inline>
/* ============================================================
   DESIGN TOKENS
   ============================================================ */
:root {
  --bg-primary: #fafaf8;
  --bg-alt: #f2f2ee;
  --bg-card: #ffffff;
  --bg-dark: #111113;
  --bg-dark-card: #1a1a1c;
  --bg-dark-subtle: #222225;
  --text-primary: #1a1a1a;
  --text-body: #3a3a3a;
  --text-muted: #71716b;
  --text-faint: #a1a19b;
  --text-on-dark: #f5f5f0;
  --text-body-dark: #b8b8b0;
  --text-muted-dark: #888880;
  --text-faint-dark: #555558;
  --accent: #c1d42f;
  --accent-hover: #d4e635;
  --accent-pressed: #a8b828;
  --accent-tint: rgba(193, 212, 47, 0.09);
  --accent-glow: rgba(193, 212, 47, 0.19);
  --cta-text: #111113;
  --border: #e2e2de;
  --border-hover: #c1d42f;
  --border-dark: #333335;
  --max-content: 1120px;
  --max-narrow: 720px;
  --max-cards: 1040px;
  --max-twocol: 880px;

  /* Tactical-frame tokens (ported from glow4 hero) */
  --frame-gap: 16px;
  --corner-len: 22%;
  --tick-len: 6%;
  --line-opacity: 0.22;
  --line-width: 1.5px;
  --light-duration: 2.4s;
  --chase-duration: 1s;
  --pattern-gap: 2s;
  --light-len: 55%;
  --light-thick: 2px;
  --light-blur: 3px;
  --light-opacity: 1;
  --desync: 0;
  --rail-extend-out: 60px;
  --rail-extend-in: 0px;
  --glow-color: #c1d42f;
  --light-end: 181.82%;
  --master-duration: 18.20s;
  --bracket-color: rgba(245, 245, 240, 0.22);
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  background: var(--bg-primary);
  color: var(--text-body);
  font-family: 'Chakra Petch', system-ui, -apple-system, sans-serif;
  font-size: 17px;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }

/* ============================================================
   NAVIGATION
   ============================================================ */
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  padding: 0 64px;
  background: transparent;
  transition: background 0.3s ease;
}
.nav {
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
}
.nav-brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Audiowide', system-ui, sans-serif;
  font-size: 18px;
  line-height: 1.15;
  letter-spacing: 0.11em;
  color: var(--text-primary);
  transition: color 0.3s ease;
}
.nav-brand-bar {
  display: block;
  width: 3px;
  height: 20px;
  background: var(--accent);
  border-radius: 2px;
  flex-shrink: 0;
}
.nav-cta {
  padding: 8px 20px;
  border-radius: 6px;
  background: var(--accent);
  color: var(--cta-text);
  font-family: 'Chakra Petch', system-ui, sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.02em;
  border: none;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.15s ease;
}
.nav-cta:hover { background: var(--accent-hover); transform: scale(1.02); }
.nav-actions { display: flex; align-items: center; gap: 12px; }
.nav-link {
  font-family: 'Chakra Petch', system-ui, sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: var(--text-primary);
  padding: 8px 14px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: transparent;
  transition: border-color 0.15s ease, color 0.15s ease;
}
.nav-link:hover { border-color: var(--accent); color: var(--accent); }

/* ============================================================
   HERO
   ============================================================ */
.hero {
  background: var(--bg-dark);
  padding: 70px 64px 120px;
  position: relative;
  overflow: hidden;
}
/* Diffuse cyan gradient blob in the upper-right of the hero */
.hero-glow-blob {
  position: absolute;
  z-index: 0;
  filter: blur(120px);
  border-radius: 9999px;
  opacity: 0.32;
  background: rgb(92, 206, 255);
  pointer-events: none;
  width: 750px;
  height: 750px;
  top: -300px;
  right: -375px;
}
/* Smaller cyan blob in the bottom-left, just barely brushing the hero text */
.hero-glow-blob-bl {
  position: absolute;
  z-index: 0;
  filter: blur(120px);
  border-radius: 9999px;
  opacity: 0.28;
  background: rgb(92, 206, 255);
  pointer-events: none;
  width: 536px;
  height: 536px;
  bottom: -198px;
  left: -243px;
}
.hero-inner {
  position: relative;
  max-width: var(--max-content);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: 44px;
  align-items: center;
}
.hero-content { position: relative; z-index: 2; }
.hero-headshot-col { position: relative; display: flex; justify-content: flex-end; }
.credential-pill {
  display: block;
  text-align: center;
  max-width: 568px;
  padding: 10px 24px;
  border: 1px solid var(--accent);
  border-radius: 20px;
  font-family: 'Audiowide', system-ui, sans-serif;
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted-dark);
  margin-bottom: 32px;
}
.hero h1 {
  font-family: 'Orbitron', system-ui, sans-serif;
  font-size: 56px;
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -0.03em;
  color: var(--text-on-dark);
  margin-bottom: 24px;
}
.hero h1 .accent { color: var(--accent); }
.hero-sub {
  font-family: 'Chakra Petch', system-ui, sans-serif;
  font-size: 20px;
  line-height: 1.6;
  color: var(--text-muted-dark);
  max-width: 540px;
  margin-bottom: 40px;
}
.hero-form { display: flex; gap: 8px; margin-bottom: 16px; }
.hero-input {
  width: 320px;
  padding: 14px 18px;
  background: var(--bg-dark-card);
  border: 1px solid var(--border-dark);
  border-radius: 8px;
  font-family: 'Chakra Petch', system-ui, sans-serif;
  font-size: 16px;
  color: var(--text-on-dark);
  outline: none;
  transition: border-color 0.15s ease;
}
.hero-input::placeholder { color: var(--text-faint-dark); }
.hero-input:focus { border-color: var(--accent); }
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 32px;
  border: none;
  border-radius: 8px;
  background: var(--accent);
  color: var(--cta-text);
  font-family: 'Chakra Petch', system-ui, sans-serif;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  white-space: nowrap;
}
.btn-primary:hover { background: var(--accent-hover); transform: scale(1.02); box-shadow: 0 4px 16px rgba(193, 212, 47, 0.25); }
.btn-primary:active { background: var(--accent-pressed); transform: scale(0.98); }
.btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
.hero-micro { font-size: 14px; line-height: 1.5; color: var(--text-faint-dark); }
.hero-form-success {
  display: none;
  align-items: center;
  gap: 10px;
  font-size: 15px;
  font-weight: 500;
  color: var(--accent);
  margin-bottom: 16px;
}
.hero-form-success.show { display: flex; }
/* ── Tactical bracket frame around the headshot (ported from glow4) ── */
.headshot-frame {
  position: relative;
  padding: var(--frame-gap);
  display: inline-block;
}
.frame-lines {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  aspect-ratio: auto;
  pointer-events: none;
  z-index: 0;
}
.frame-lines path {
  stroke: var(--bracket-color);
  stroke-width: var(--line-width);
  fill: none;
  vector-effect: non-scaling-stroke;
}
.light-rail {
  position: absolute;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
  opacity: var(--light-opacity);
}
.light-rail::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(var(--gradient-angle, 90deg), transparent 0%, var(--glow-color) 50%, transparent 100%);
  filter: drop-shadow(0 0 var(--light-blur) var(--glow-color));
}
.light-rail.tl { top: 0; left: calc(-1 * var(--rail-extend-out)); width: calc(var(--corner-len) + var(--rail-extend-out) + var(--rail-extend-in)); height: var(--light-thick); }
.light-rail.tl::before { width: var(--light-len); height: 100%; --gradient-angle: 90deg; animation: travel-h-pattern var(--master-duration) linear infinite; }
.light-rail.tr { top: calc(-1 * var(--rail-extend-out)); right: 0; width: var(--light-thick); height: calc(var(--corner-len) + var(--rail-extend-out) + var(--rail-extend-in)); }
.light-rail.tr::before { width: 100%; height: var(--light-len); --gradient-angle: 180deg; animation: travel-v-pattern var(--master-duration) linear infinite; animation-delay: calc(var(--light-duration) * var(--desync, 0) * -0.25); }
.light-rail.br { bottom: 0; right: calc(-1 * var(--rail-extend-out)); width: calc(var(--corner-len) + var(--rail-extend-out) + var(--rail-extend-in)); height: var(--light-thick); }
.light-rail.br::before { width: var(--light-len); height: 100%; right: 0; left: auto; --gradient-angle: 270deg; animation: travel-h-rev-pattern var(--master-duration) linear infinite; animation-delay: calc(var(--light-duration) * var(--desync, 0) * -0.5); }
.light-rail.bl { bottom: calc(-1 * var(--rail-extend-out)); left: 0; width: var(--light-thick); height: calc(var(--corner-len) + var(--rail-extend-out) + var(--rail-extend-in)); }
.light-rail.bl::before { width: 100%; height: var(--light-len); bottom: 0; top: auto; --gradient-angle: 0deg; animation: travel-v-rev-pattern var(--master-duration) linear infinite; animation-delay: calc(var(--light-duration) * var(--desync, 0) * -0.75); }

/* Pattern keyframes — 6× cycle: all → V → H → chase TR → BR → BL with 2s rests.
   Master = 3*L + 3*C + 4*G = 3*2.4 + 3*1 + 4*2 = 18.20s. */
@keyframes travel-h-pattern {
  0.000%   { transform: translateX(-100%); opacity: 0; }
  1.319%   { opacity: 1; }
  11.868%  { opacity: 1; }
  13.187%  { transform: translateX(var(--light-end)); opacity: 0; }
  13.197%  { transform: translateX(-100%); opacity: 0; }
  24.176%  { transform: translateX(var(--light-end)); opacity: 0; }
  24.186%  { transform: translateX(-100%); opacity: 0; }
  37.363%  { transform: translateX(var(--light-end)); opacity: 0; }
  37.373%  { transform: translateX(-100%); opacity: 0; }
  48.352%  { transform: translateX(var(--light-end)); opacity: 0; }
  48.362%  { transform: translateX(-100%); opacity: 0; }
  49.681%  { opacity: 1; }
  60.219%  { opacity: 1; }
  61.538%  { transform: translateX(var(--light-end)); opacity: 0; }
  61.548%  { transform: translateX(-100%); opacity: 0; }
  72.527%  { transform: translateX(var(--light-end)); opacity: 0; }
  72.537%  { transform: translateX(-100%); opacity: 0; }
  78.022%  { transform: translateX(var(--light-end)); opacity: 0; }
  78.032%  { transform: translateX(-100%); opacity: 0; }
  83.516%  { transform: translateX(var(--light-end)); opacity: 0; }
  83.526%  { transform: translateX(-100%); opacity: 0; }
  89.011%  { transform: translateX(var(--light-end)); opacity: 0; }
  89.021%  { transform: translateX(-100%); opacity: 0; }
  100%     { transform: translateX(var(--light-end)); opacity: 0; }
}
@keyframes travel-v-pattern {
  0.000%   { transform: translateY(-100%); opacity: 0; }
  1.319%   { opacity: 1; }
  11.868%  { opacity: 1; }
  13.187%  { transform: translateY(var(--light-end)); opacity: 0; }
  13.197%  { transform: translateY(-100%); opacity: 0; }
  24.176%  { transform: translateY(var(--light-end)); opacity: 0; }
  24.186%  { transform: translateY(-100%); opacity: 0; }
  25.505%  { opacity: 1; }
  36.044%  { opacity: 1; }
  37.363%  { transform: translateY(var(--light-end)); opacity: 0; }
  37.373%  { transform: translateY(-100%); opacity: 0; }
  48.352%  { transform: translateY(var(--light-end)); opacity: 0; }
  48.362%  { transform: translateY(-100%); opacity: 0; }
  61.538%  { transform: translateY(var(--light-end)); opacity: 0; }
  61.548%  { transform: translateY(-100%); opacity: 0; }
  72.527%  { transform: translateY(var(--light-end)); opacity: 0; }
  72.537%  { transform: translateY(-100%); opacity: 1; }
  78.022%  { transform: translateY(var(--light-end)); opacity: 1; }
  78.032%  { transform: translateY(-100%); opacity: 0; }
  83.516%  { transform: translateY(var(--light-end)); opacity: 0; }
  83.526%  { transform: translateY(-100%); opacity: 0; }
  89.011%  { transform: translateY(var(--light-end)); opacity: 0; }
  89.021%  { transform: translateY(-100%); opacity: 0; }
  100%     { transform: translateY(var(--light-end)); opacity: 0; }
}
@keyframes travel-h-rev-pattern {
  0.000%   { transform: translateX(100%); opacity: 0; }
  1.319%   { opacity: 1; }
  11.868%  { opacity: 1; }
  13.187%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  13.197%  { transform: translateX(100%); opacity: 0; }
  24.176%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  24.186%  { transform: translateX(100%); opacity: 0; }
  37.363%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  37.373%  { transform: translateX(100%); opacity: 0; }
  48.352%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  48.362%  { transform: translateX(100%); opacity: 0; }
  49.681%  { opacity: 1; }
  60.219%  { opacity: 1; }
  61.538%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  61.548%  { transform: translateX(100%); opacity: 0; }
  72.527%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  72.537%  { transform: translateX(100%); opacity: 0; }
  78.022%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  78.032%  { transform: translateX(100%); opacity: 1; }
  83.516%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 1; }
  83.526%  { transform: translateX(100%); opacity: 0; }
  89.011%  { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
  89.021%  { transform: translateX(100%); opacity: 0; }
  100%     { transform: translateX(calc(-1 * var(--light-end))); opacity: 0; }
}
@keyframes travel-v-rev-pattern {
  0.000%   { transform: translateY(100%); opacity: 0; }
  1.319%   { opacity: 1; }
  11.868%  { opacity: 1; }
  13.187%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  13.197%  { transform: translateY(100%); opacity: 0; }
  24.176%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  24.186%  { transform: translateY(100%); opacity: 0; }
  25.505%  { opacity: 1; }
  36.044%  { opacity: 1; }
  37.363%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  37.373%  { transform: translateY(100%); opacity: 0; }
  48.352%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  48.362%  { transform: translateY(100%); opacity: 0; }
  61.538%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  61.548%  { transform: translateY(100%); opacity: 0; }
  72.527%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  72.537%  { transform: translateY(100%); opacity: 0; }
  78.022%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  78.032%  { transform: translateY(100%); opacity: 0; }
  83.516%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
  83.526%  { transform: translateY(100%); opacity: 1; }
  89.011%  { transform: translateY(calc(-1 * var(--light-end))); opacity: 1; }
  89.021%  { transform: translateY(100%); opacity: 0; }
  100%     { transform: translateY(calc(-1 * var(--light-end))); opacity: 0; }
}
@media (prefers-reduced-motion: reduce) {
  .light-rail::before { animation: none; opacity: 0.5; }
}

/* Photo card with caption overlay */
.headshot-card {
  position: relative;
  z-index: 2;
  width: 380px;
  aspect-ratio: 3/4;
  display: flex;
  flex-direction: column;
  border-radius: 16px;
  background: linear-gradient(160deg, #1a1a1c 0%, #0e0e10 100%);
  overflow: hidden;
  isolation: isolate;
}
.headshot-photo { position: absolute; inset: 0; }
.headshot-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.95;
  mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
  -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);
}
.headshot-fade {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 50%;
  z-index: 1;
  background: linear-gradient(to top, rgba(17,17,19,0.95) 0%, rgba(17,17,19,0.6) 50%, transparent 100%);
}
.headshot-caption {
  position: relative;
  z-index: 2;
  margin-top: auto;
  padding: 32px;
}
.headshot-caption .label {
  font-family: 'Audiowide', system-ui, sans-serif;
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 8px;
}
.headshot-caption h3 {
  font-family: 'Orbitron', system-ui, sans-serif;
  font-size: 24px;
  font-weight: 700;
  color: var(--text-on-dark);
  margin-bottom: 8px;
}
.headshot-caption p {
  font-size: 14px;
  color: var(--text-body-dark);
}
.spine-line {
  position: absolute;
  width: 1px;
  top: 12px;
  bottom: 12px;
  background: linear-gradient(to bottom, transparent, rgba(193, 212, 47, 0.35), transparent);
}
.spine-line.s1 { left: 12px; }
.spine-line.s2 { left: 13px; opacity: 0.5; }

/* ============================================================
   SECTIONS
   ============================================================ */
.section { padding: 120px 64px; }
.section-white { background: var(--bg-card); }
.section-alt { background: var(--bg-alt); }
.section-inner { max-width: var(--max-content); margin: 0 auto; }
.section-inner.narrow { max-width: var(--max-narrow); }
.section-pill {
  display: inline-block;
  padding: 4px 14px;
  border: 1px solid var(--accent);
  border-radius: 20px;
  font-family: 'Audiowide', system-ui, sans-serif;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 32px;
}
h2 {
  font-family: 'Orbitron', system-ui, sans-serif;
  font-size: 36px;
  font-weight: 600;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: var(--text-primary);
}
h2.on-dark { color: var(--text-on-dark); }
h2 .accent { color: var(--accent); }
.section-sub { font-size: 18px; line-height: 1.6; color: var(--text-muted); }
.text-center { text-align: center; }

/* Problem */
.problem-body { max-width: 640px; margin: 48px auto 0; text-align: left; }
.problem-body p { margin-bottom: 24px; color: var(--text-body); }
.problem-body p:last-child { color: var(--text-primary); font-weight: 500; margin-bottom: 0; }

/* Cards */
.card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: var(--max-cards); margin: 0 auto; }
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 32px;
  transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}
.card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
.card-icon {
  width: 44px; height: 44px;
  background: var(--accent-tint);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px;
}
.card-icon svg { width: 24px; height: 24px; stroke: var(--accent); stroke-width: 1.5; fill: none; }
h3 {
  font-family: 'Orbitron', system-ui, sans-serif;
  font-size: 20px; font-weight: 600; line-height: 1.3;
  letter-spacing: -0.01em; color: var(--text-primary);
  margin-bottom: 12px;
}
.card p { font-size: 15px; line-height: 1.65; color: var(--text-body); }

/* Career */
.career-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
.career-block { border-left: 3px solid var(--accent); padding-left: 24px; }
