<script is:inline>
  // ── Substack subscribe (direct browser POST to bypass Cloudflare) ──
  async function handleSubscribe(inputId, formWrapId, successId, btnId) {
    const input = document.getElementById(inputId);
    const btn = document.getElementById(btnId);
    const email = input?.value?.trim();
    if (!email) { input?.focus(); return; }

    btn.disabled = true;

    try {
      const res = await fetch('https://jasonclewis.substack.com/api/v1/free', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: email,
          first_url: window.location.href,
          current_url: window.location.href,
          current_referrer: document.referrer || '',
          source: 'custom_embed',
          public_brand: 'jason-c-lewis'
        }),
      });

      if (res.ok) {
        document.getElementById(formWrapId).style.display = 'none';
        document.getElementById(successId).classList.add('show');
      } else {
        alert('Something went wrong. Please try again.');
        btn.disabled = false;
      }
    } catch {
      // CORS or network error — fall back to opening Substack directly
      window.open('https://jasonclewis.substack.com/subscribe?email=' + encodeURIComponent(email), '_blank');
      document.getElementById(formWrapId).style.display = 'none';
      document.getElementById(successId).classList.add('show');
    }
  }
</script>

