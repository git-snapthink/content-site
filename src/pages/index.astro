    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    border-radius: 9999px;
    font-family: system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.5s cubic-bezier(0.32, 0.72, 0, 1);
