---
import LandingLayout from '../layouts/LandingLayout.astro';

const brand = import.meta.env.PUBLIC_BRAND;
const isJCL = brand === 'jason-c-lewis';
---

{isJCL ? (
<LandingLayout
  title="Jason C. Lewis — AI Strategy, Leadership & Execution"
  description="Strategic AI and leadership insight from someone who's been in the room — AWS, Gartner, and multiple technology ventures. Zero hype. Maximum signal."
  navLinks={[
    { label: 'Background', href: '#background' },
    { label: 'Writing', href: '#themes' },
    { label: 'Articles', href: '/articles' },
  ]}
  ctaLabel="Subscribe"
  ctaHref="#subscribe"
>

  <!-- ════════════════════════════════════════
       HERO
       ════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-orb hero-orb--primary"></div>
    <div class="hero-orb hero-orb--secondary"></div>
    <div class="hero-orb hero-orb--center"></div>

    <div class="hero-content">
      <div class="eyebrow">
        <span class="dot"></span>
        AI Strategy &middot; Leadership &middot; Execution
      </div>
      <h1>Jason C. Lewis</h1>
      <p class="hero-sub">
        Strategic AI and leadership insight from someone who's been in the room — leading Startups and AI support at AWS, managing the Data and Analytics practice at Gartner, and building technology ventures. Zero hype. Maximum signal.
      </p>
      <div class="hero-ctas">
        <a href="#subscribe" class="cta-btn">
          Subscribe to Newsletter
          <span class="btn-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </a>
        <a href="https://www.linkedin.com/in/jasonclewis/" target="_blank" rel="noopener" class="cta-btn cta-btn--secondary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Follow on LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       BACKGROUND / CREDIBILITY
       ════════════════════════════════════════ -->
  <section class="section background" id="background">
    <div class="container">
      <div class="section-header reveal">
        <div class="eyebrow">
          <span class="dot"></span>
          Background
        </div>
        <h2>Operator Credibility at <span class="accent">Every Altitude</span></h2>
        <p>Two decades at the intersection of cloud, AI, and leadership — from hyperscale to startup to the advisory boardroom.</p>
      </div>

      <div class="cards-grid">
        <div class="card reveal reveal-delay-1">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <div class="card-label">Amazon Web Services</div>
          <h3>AI Startup Leadership</h3>
          <p>Leading Premium Support for the most prominent AI and cloud startups across North America. Seeing what's actually working in production — not what's being demo'd at conferences.</p>
        </div>

        <div class="card reveal reveal-delay-2">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <div class="card-label">Gartner</div>
          <h3>Enterprise AI Advisory</h3>
          <p>Directed the global Data & Analytics practice for 14,000+ organizations. Shaped how executives think about AI and data strategy through keynotes at international events.</p>
        </div>

        <div class="card reveal reveal-delay-3">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
          </div>
          <div class="card-label">Ventures</div>
          <h3>Founder & Advisor</h3>
          <p>Founded and sold multiple technology ventures. Served as venture advisor conducting technical due diligence and acting as interim CIO/CTO — from founding through scaling through exit.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       THEMES / WHAT I WRITE ABOUT
       ════════════════════════════════════════ -->
  <section class="section themes" id="themes">
    <div class="container">
      <div class="section-header reveal">
        <div class="eyebrow">
          <span class="dot"></span>
          What I Write About
        </div>
        <h2>Signal Over <span class="accent">Noise</span></h2>
        <p>In a landscape flooded with breathless AI takes and doomsday predictions, this is the place for calibrated, experience-grounded perspective.</p>
      </div>

      <div class="themes-grid">
        <div class="theme-card reveal reveal-delay-1">
          <span class="theme-number">01</span>
          <h3>AI Strategy Requires Operating Experience</h3>
          <p>Insights come from leading AI initiatives at AWS and Gartner and building ventures — not from reading papers or interviewing practitioners.</p>
        </div>

        <div class="theme-card reveal reveal-delay-2">
          <span class="theme-number">02</span>
          <h3>The Execution Gap Is Where Organizations Fail</h3>
          <p>Most companies have an AI strategy. Very few have AI execution. The value is in translating vision into infrastructure, teams, and results.</p>
        </div>

        <div class="theme-card reveal reveal-delay-3">
          <span class="theme-number">03</span>
          <h3>Leadership Is the Multiplier</h3>
          <p>AI doesn't replace leadership — it amplifies it. Great leaders use AI to build higher-performing teams. The technology is neutral; the leadership isn't.</p>
        </div>

        <div class="theme-card reveal reveal-delay-1">
          <span class="theme-number">04</span>
          <h3>The Startup-Enterprise Bridge</h3>
          <p>What startups get right about speed, enterprises get right about scale. The best organizations learn from both. This cross-pollination perspective is rare.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       SUBSCRIBE CTA
       ════════════════════════════════════════ -->
  <section class="section cta-section" id="subscribe">
    <div class="container">
      <div class="cta-content reveal">
        <h2>Get the <span class="accent">Signal</span></h2>
        <p>Strategic AI and leadership perspective, delivered to your inbox. No hype. No spam. Just the insight that matters.</p>
        <form class="cta-shell" id="ctaForm">
          <div class="cta-inner">
            <input type="email" placeholder="you@company.com" required />
            <button type="submit" class="cta-btn">
              Subscribe
              <span class="btn-arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </button>
          </div>
        </form>
        <div class="form-success" id="ctaSuccess">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          You're on the list. Welcome aboard.
        </div>
        <p class="trust-text">Free. No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

</LandingLayout>
) : (
<LandingLayout
  title="NextBuild — AI Tools, Frameworks & Guides for Builders"
  description="NextBuild helps founders and builders ship AI-powered products faster with practical frameworks, guides, and real implementation strategies."
>

  <!-- ════════════════════════════════════════
       HERO
       ════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-orb hero-orb--primary"></div>
    <div class="hero-orb hero-orb--secondary"></div>
    <div class="hero-orb hero-orb--center"></div>

    <div class="hero-content">
      <div class="eyebrow">
        <span class="dot"></span>
        For Builders & Founders
      </div>
      <h1>Stop Researching.<br/><span class="accent">Start Building.</span></h1>
      <p class="hero-sub">
        NextBuild gives you the AI playbooks, tools, and community to build, launch and grow your business.
      </p>
      <form class="cta-shell" id="heroForm">
        <div class="cta-inner">
          <input type="email" placeholder="you@company.com" required />
          <button type="submit" class="cta-btn">
            Get Early Access
            <span class="btn-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </button>
        </div>
      </form>
      <div class="form-success" id="heroSuccess">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        You're on the list. We'll be in touch.
      </div>
      <p class="trust-text">Free to join. No spam. Just early access.</p>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       PROBLEM
       ════════════════════════════════════════ -->
  <section class="section problem" id="problem">
    <div class="container">
      <div class="section-header reveal">
        <div class="eyebrow">
          <span class="dot"></span>
          The Challenge
        </div>
        <h2>Everyone Talks AI.<br/>Almost Nobody Ships.</h2>
        <p>The gap between AI potential and real products isn't knowledge — it's knowing what to build and how to actually ship it.</p>
      </div>

      <div class="cards-grid">
        <div class="card reveal reveal-delay-1">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="m7 8 3 3-3 3"/><line x1="13" y1="14" x2="17" y2="14"/></svg>
          </div>
          <h3>Information Overload</h3>
          <p>Hundreds of AI tools launch weekly. You don't need more options — you need the right ones.</p>
        </div>

        <div class="card reveal reveal-delay-2">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Tutorial Hell</h3>
          <p>Watching demos isn't building. You need actionable playbooks, not another webinar.</p>
        </div>

        <div class="card reveal reveal-delay-3">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Building Alone</h3>
          <p>Solo founders shouldn't mean solo debugging. The best builders learn from other builders.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       HOW IT WORKS
       ════════════════════════════════════════ -->
  <section class="section how-it-works" id="how-it-works">
    <div class="container">
      <div class="section-header reveal">
        <div class="eyebrow">
          <span class="dot"></span>
          How It Works
        </div>
        <h2>From Idea to <span class="accent">Shipped Product</span></h2>
        <p>A practical framework that cuts through the noise and gets you building.</p>
      </div>

      <div class="steps-grid">
        <div class="step-card reveal reveal-delay-1">
          <span class="step-number">01</span>
          <h3>Pick a Playbook</h3>
          <p>Choose from battle-tested AI implementation guides for your specific use case.</p>
        </div>

        <div class="step-card reveal reveal-delay-2">
          <span class="step-number">02</span>
          <h3>Follow the Steps</h3>
          <p>Each playbook is a concrete sequence — prompts, tools, workflows — not theory.</p>
        </div>

        <div class="step-card reveal reveal-delay-3">
          <span class="step-number">03</span>
          <h3>Ship & Iterate</h3>
          <p>Launch something real in days, not months. Refine with community feedback.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       FEATURES / WHAT YOU GET
       ════════════════════════════════════════ -->
  <section class="section features" id="what-you-get">
    <div class="container">
      <div class="section-header reveal">
        <div class="eyebrow">
          <span class="dot"></span>
          What You Get
        </div>
        <h2>Everything You Need to <span class="accent">Build With AI</span></h2>
      </div>

      <div class="features-grid">
        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="m10 13-2 2 2 2"/><path d="m14 17 2-2-2-2"/></svg>
          </div>
          <h3>AI Playbooks</h3>
          <p>Step-by-step implementation guides for real AI builds — from prompt engineering to production deployment.</p>
        </div>

        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21 21-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0z"/></svg>
          </div>
          <h3>Tool Reviews</h3>
          <p>Honest breakdowns of AI tools and platforms — no affiliate spam, just what actually works for builders.</p>
        </div>

        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Founder Stories</h3>
          <p>Real builders sharing real lessons — what worked, what didn't, and what they'd do differently.</p>
        </div>

        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3>Weekly Briefing</h3>
          <p>Curated AI news that matters for builders — market shifts, new tools, and strategies worth your time.</p>
        </div>

        <div class="feature-card reveal reveal-delay-1">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
          </div>
          <h3>Early Access to Tools</h3>
          <p>Be first in line for AI-powered tools and templates designed to compress your time from idea to revenue.</p>
        </div>

        <div class="feature-card reveal reveal-delay-2">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3>Builder Community</h3>
          <p>Connect with founders actively shipping AI products — share wins, get feedback, stay accountable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════
       CTA
       ════════════════════════════════════════ -->
  <section class="section cta-section" id="cta">
    <div class="container">
      <div class="cta-content reveal">
        <h2>Ready to <span class="accent">Build</span>?</h2>
        <p>Join builders and founders who are done learning and ready to ship. Get early access to playbooks, tools, and community.</p>
        <form class="cta-shell" id="ctaForm">
          <div class="cta-inner">
            <input type="email" placeholder="you@company.com" required />
            <button type="submit" class="cta-btn">
              Reserve My Spot
              <span class="btn-arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </button>
          </div>
        </form>
        <div class="form-success" id="ctaSuccess">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          You're on the list. We'll be in touch.
        </div>
        <p class="trust-text">No spam. No obligation. Just first access.</p>
      </div>
    </div>
  </section>

</LandingLayout>
)}

<style>
  /* ════════════════════════════════════════
     HERO
     ════════════════════════════════════════ */
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
  }

  .hero-orb--primary {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 15%, transparent), transparent 70%);
    top: -10%;
    right: -5%;
    opacity: 0.8;
  }

  .hero-orb--secondary {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 10%, transparent), transparent 70%);
    bottom: 10%;
    left: -5%;
    opacity: 0.6;
  }

  .hero-orb--center {
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 6%, transparent), transparent 60%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 820px;
  }

  .hero .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid var(--border);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--textMuted);
    margin-bottom: 28px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero h1 {
    font-family: var(--displayFont);
    font-size: clamp(40px, 6vw, 68px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 28px;
    color: var(--text);
  }

  .hero h1 .accent {
    color: var(--accent);
  }

  .hero-sub {
    font-size: clamp(17px, 2vw, 20px);
    color: var(--textMuted);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 48px;
    font-weight: 400;
  }

  /* ── Hero CTAs (JCL variant) ── */
  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-btn--secondary {
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    border-radius: 9999px;
    font-family: system-ui, sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
