  .card h3 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--text);
  }

  .card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
  }

  /* ════════════════════════════════════════
     THEMES GRID (JCL)
     ════════════════════════════════════════ */
  .themes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .theme-card {
    padding: 36px 32px;
    border-radius: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .theme-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
    transform: translateY(-4px);
  }

  .theme-number {
    display: block;
    font-family: var(--displayFont);
    font-size: 42px;
    font-weight: 700;
    color: var(--accent-tint);
    line-height: 1;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .theme-card h3 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--text);
  }

  .theme-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
  }

  /* ════════════════════════════════════════
     HOW IT WORKS — STEPS (NextBuild)
     ════════════════════════════════════════ */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .step-card {
    padding: 36px 32px;
    border-radius: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
