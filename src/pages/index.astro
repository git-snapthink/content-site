    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  .step-card h3 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--text);
  }

  .step-card p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--textMuted);
